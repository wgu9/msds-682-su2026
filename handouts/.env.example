# Copy to .env and fill values locally. Never submit or publish .env.
BOOTSTRAP_SERVERS=
SECURITY_PROTOCOL=SASL_SSL
SASL_MECHANISMS=PLAIN
SASL_USERNAME=
SASL_PASSWORD=

# Schema Registry credentials are separate from Kafka credentials, but a valid
# Registry key may be reused by Demo 04 and Demo 05 for the same Registry.
SCHEMA_REGISTRY_URL=
SCHEMA_REGISTRY_API_KEY=
SCHEMA_REGISTRY_API_SECRET=

# Nonsecret course defaults. Change only when a handout tells you to.
DEMO01_TOPIC_NAME=msds682.demo01.trip-events.v1
DEMO04_TOPIC_NAME=msds682.demo04.trip-events-avro.v1
DEMO05_TOPIC_NAME=msds682.demo05.trip-events-api-avro.v1
CONSUMER_GROUP_ID_PREFIX=msds682-su2026
