# Copy to .env and fill values locally. Never submit or publish .env.
BOOTSTRAP_SERVERS=
SECURITY_PROTOCOL=SASL_SSL
SASL_MECHANISMS=PLAIN
SASL_USERNAME=
SASL_PASSWORD=

# Schema Registry credentials are separate from Kafka credentials, but a valid
# Registry key may be reused by Demo 04 through Demo 07 for the same Registry.
SCHEMA_REGISTRY_URL=
SCHEMA_REGISTRY_API_KEY=
SCHEMA_REGISTRY_API_SECRET=

# Nonsecret course defaults. Change only when a handout tells you to.
DEMO01_TOPIC_NAME=msds682.demo01.trip-events.v1
DEMO04_TOPIC_NAME=msds682.demo04.trip-events-avro.v1
DEMO05_TOPIC_NAME=msds682.demo05.trip-events-api-avro.v1
DEMO06_INPUT_TOPIC_NAME=msds682.demo06.connector-orders-avro.v1
DEMO06_OUTPUT_TOPIC_NAME=msds682.demo06.connector-order-metrics-avro.v1
DEMO07_TRIP_REQUESTS_TOPIC=msds682.demo07.ml-trip-requests-avro.v1
DEMO07_FARE_QUOTES_TOPIC=msds682.demo07.ml-fare-quotes-avro.v1
DEMO07_TRIP_OUTCOMES_TOPIC=msds682.demo07.ml-trip-outcomes-avro.v1
DEMO07_PRICING_EVALUATIONS_TOPIC=msds682.demo07.ml-pricing-evaluations-avro.v1
CONSUMER_GROUP_ID_PREFIX=msds682-su2026
