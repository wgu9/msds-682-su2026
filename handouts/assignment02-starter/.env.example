# Copy to .env and fill values locally. Never submit or publish .env.
BOOTSTRAP_SERVERS=
SECURITY_PROTOCOL=SASL_SSL
SASL_MECHANISMS=PLAIN
SASL_USERNAME=
SASL_PASSWORD=

# Schema Registry credentials are separate from Kafka credentials.
SCHEMA_REGISTRY_URL=
SCHEMA_REGISTRY_API_KEY=
SCHEMA_REGISTRY_API_SECRET=

# Nonsecret Assignment 2 defaults.
ASSIGNMENT2_TOPIC_NAME=msds682.assignment02.trip-events-api-avro.v1
ASSIGNMENT2_GROUP_ID=msds682.assignment02.<usf_username>.base.v1
